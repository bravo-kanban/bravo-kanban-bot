# ─── GitHub App credentials ────────────────────────────────────────────────────
# App ID из настроек GitHub App (Settings → Developer settings → GitHub Apps)
APP_ID=

# Путь к файлу с приватным ключом GitHub App (.pem)
PRIVATE_KEY_PATH=/app/private-key.pem

# Webhook secret (должен совпадать с настройкой в GitHub App)
WEBHOOK_SECRET=

# ─── OpenRouter LLM (опционально) ─────────────────────────────────────────────
# Ключ API OpenRouter для AI-функций (Guardian enhanced checks, /ai command)
# Без ключа бот работает только на регулярных выражениях
OPENROUTER_API_KEY=

# ─── GitHub Organization ───────────────────────────────────────────────────────
GITHUB_ORG=bravo-kanban

# Репозитории для проверки WIP-лимита (через запятую)
GUARDIAN_REPOS=sur-tasks,sur-bravo,fd-tasks

# ─── GitHub Projects V2 ────────────────────────────────────────────────────────
# ID проекта "Kanban СУР"
PROJECT_ID=PVT_kwDOEGF_kM4BUKVd

# ID поля Status в проекте
STATUS_FIELD_ID=PVTSSF_lADOEGF_kM4BUKVdzhBUXxk

# ─── Limits ───────────────────────────────────────────────────────────────────
# Максимальное количество задач In Progress на одного исполнителя
WIP_LIMIT=3

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
